# Fleet Copilot — Environment Variables
# Copy to .env.local for local development

# Required: DeepInfra API key for DeepSeek V4 Flash
DEEPINFRA_API_KEY=sk-your-deepinfra-api-key-here

# Optional: Override model name
# FLEET_MODEL=deepseek-ai/DeepSeek-V4-Flash

# Optional: Override API base URL
# DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai
